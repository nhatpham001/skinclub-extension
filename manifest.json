{
  "manifest_version": 3,
  "name": "SkinClub Price Checker",
  "version": "1.0.0",
  "description": "Shows CSFloat market prices on Skin.club",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://skinclub-extension.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://skin.club/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
